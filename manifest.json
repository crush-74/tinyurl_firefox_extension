{
  "name": "TinyURL Extension",
  "description": "Extension to quickly create and copy Tiny URLs",
  "version": "1.1",
  "manifest_version": 3,
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "notifications",
    "clipboardWrite"
  ],
  "action": {
    "default_title": "CreateTiny URL",
    "default_icon": "images/link.png"
  },
  "background": {
    "service_worker": "background/background.js",
    "scripts": ["background/background.js"],
    "type": "module"
  },
  "options_page": "options/options.html",
    "browser_specific_settings": {
    "gecko": {
      "id": "tinyurl_firefox@lumata.us",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}